{
    // Only put changed values in here
    // The rest will automatically be set to their defaults

	// These settings seem to affect zoom scrolling too despite having seperate configs
	zoom_transition: {
		// options: INSTANT, LINEAR, SMOOTH, SINE, BALANCED, SPRING
		// default: SMOOTH
		start_transition: "INSTANT",
		// options: INSTANT, LINEAR, SMOOTH, SINE, BALANCED, SPRING
		// default: SMOOTH
		end_transition: "INSTANT",
	},
	// Require Spyglass too zoom, not required in creative mode
	controls: {
		// options: OFF, REQUIRE_ITEM, REPLACE_ZOOM, BOTH
		// default: OFF
		spyglass_mode: "REQUIRE_ITEM"
	},
	tweaks: {
		// Prints a random owo in the console when the game starts.
		// default: true
		print_owo_on_start: false,
	}
}
